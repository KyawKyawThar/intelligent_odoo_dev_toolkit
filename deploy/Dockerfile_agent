# ─────────────────────────────────────────────
# Stage 1: Build
# ─────────────────────────────────────────────
FROM golang:1.23-alpine AS builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w -X main.version=$(git describe --tags --always --dirty 2>/dev/null || echo dev)" \
    -o /bin/agent ./cmd/agent

# ─────────────────────────────────────────────
# Stage 2: Runtime
# ─────────────────────────────────────────────
# Minimal image — agent ships to customer servers
FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

RUN addgroup -S odoodt && adduser -S odoodt -G odoodt

WORKDIR /app

COPY --from=builder /bin/agent .

# Config file mounted by customer
VOLUME ["/etc/odoodevtools"]

USER odoodt

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD pgrep agent || exit 1

ENTRYPOINT ["./agent", "--config", "/etc/odoodevtools/agent.yaml"]